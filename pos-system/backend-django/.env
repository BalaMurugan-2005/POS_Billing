# Django local dev environment — do NOT commit real credentials
DJANGO_SECRET_KEY=django-insecure-local-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — use DATABASE_URL for a single connection string
# Local example: postgresql://postgres:password@localhost:5432/pos_system
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/pos_system

# JWT secret (keep in sync with Spring Boot JWT_SECRET_KEY)
JWT_SECRET_KEY=your-local-jwt-secret

# Email (optional for dev)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@pos.com

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
